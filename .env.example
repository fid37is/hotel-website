# .env.local
WEBSITE_BASE_DOMAIN=miravance.io
DEV_ORG_ID=0000-0000-0000-0000  # dev only
# Your HMS public API base URL
VITE_API_BASE_URL=http://localhost:3000/api/v1/public
VITE_HMS_BASE_URL=http://localhost:3000/api/v1/public
VITE_HMS_API_KEY=pk_test_xxxxxxxxxxxx

#VITE_API_BASE_URL=https://hms-backend-xh5l.onrender.com/api/v1/public


# Paystack or Flutterwave public key
VITE_PAYMENT_PUBLIC_KEY=pk_test_xxxxxxxxxxxx




# ─── .env.example ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ──────────────────────────────────────────────────────────────────────────────

# HMS public API base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:3000/api/v1/public

# HMS public API key (issued by your HMS instance)
VITE_HMS_API_KEY=pk_test_xxxxxxxxxxxx

# Socket.io server URL — defaults to VITE_API_BASE_URL host if omitted
# Set explicitly when the socket server runs on a different origin/port.
VITE_SOCKET_URL=http://localhost:5000

# Paystack public key (only required if payment.paystackEnabled = true in hotel.config.js)
VITE_PAYMENT_PUBLIC_KEY=pk_test_xxxxxxxxxxxx